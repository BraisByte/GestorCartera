<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.gestorcartera.ActivoDialogController"
      spacing="14" style="-fx-padding: 24; -fx-background-color: #1e1e2e; -fx-min-width: 380;">

    <Label text="Activo"
           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="5">
        <Label text="Nombre del activo *" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
        <TextField fx:id="campoNombre" promptText="Ej: MSCI World, Bitcoin..."
                   style="-fx-background-color: #2d2d3f; -fx-text-fill: white;
                          -fx-prompt-text-fill: #666680; -fx-padding: 8;
                          -fx-background-radius: 6; -fx-border-color: #44445a; -fx-border-radius: 6;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Tipo *" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
        <ComboBox fx:id="campoTipo" maxWidth="Infinity"
                  style="-fx-background-color: #2d2d3f; -fx-text-fill: white;"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Cantidad invertida (€) *" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
            <TextField fx:id="campoInvertido" promptText="Ej: 3000"
                       style="-fx-background-color: #2d2d3f; -fx-text-fill: white;
                              -fx-prompt-text-fill: #666680; -fx-padding: 8;
                              -fx-background-radius: 6; -fx-border-color: #44445a; -fx-border-radius: 6;"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Valor actual (€) *" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
            <TextField fx:id="campoValorActual" promptText="Ej: 3450"
                       style="-fx-background-color: #2d2d3f; -fx-text-fill: white;
                              -fx-prompt-text-fill: #666680; -fx-padding: 8;
                              -fx-background-radius: 6; -fx-border-color: #44445a; -fx-border-radius: 6;"/>
        </VBox>
    </HBox>

    <VBox spacing="5">
        <Label text="Fecha de compra *" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
        <DatePicker fx:id="campoFecha" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Notas (opcional)" style="-fx-text-fill: #aaaacc; -fx-font-size: 12px;"/>
        <TextArea fx:id="campoNotas" promptText="Ej: Comprado por DCA mensual..."
                  prefRowCount="3"
                  style="-fx-background-color: #2d2d3f; -fx-text-fill: white;
                         -fx-prompt-text-fill: #666680; -fx-padding: 8;
                         -fx-background-radius: 6; -fx-border-color: #44445a; -fx-border-radius: 6;"/>
    </VBox>

    <Label fx:id="labelError" style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#onCancelar"
                style="-fx-background-color: #3d3d50; -fx-text-fill: white;
                       -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="Confirmar" onAction="#onConfirmar"
                style="-fx-background-color: #7c6af7; -fx-text-fill: white;
                       -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>
</VBox>